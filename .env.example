# Copy to .env and fill in.
#
# Required: set EXACTLY ONE of MNEMONIC or PRIVATE_KEY for the EVM wallet that
# will sign trades. Wallet must be funded with USDC on the target Nibiru chain.
#
# Mnemonic: 12/24-word BIP-39 seed phrase. Uses DERIVATION_PATH below.
MNEMONIC=""

# Private key: 64-char hex (with or without 0x prefix). DERIVATION_PATH is
# ignored when PRIVATE_KEY is set.
PRIVATE_KEY=""

# Required for webhook server: shared secret TradingView must include in alerts
# (in the alert message JSON as "secret"). Rotate regularly.
WEBHOOK_SECRET=""

# Optional (defaults shown)
# CHAIN may be Mainnet or Testnet2.
CHAIN=Mainnet

# Override the chain's default RPC / keeper endpoints. Useful for switching
# to a private/dedicated provider under load.
# EVM_RPC=
# SAI_KEEPER_ENDPOINT=

# BIP-44 path.
DERIVATION_PATH=m/44'/60'/0'/0/0

# Slippage tolerance, percent.
DEFAULT_SLIPPAGE_PCT=1

# Set true to simulate without broadcasting.
DRY_RUN=false

# Webhook server
PORT=3030
BIND=127.0.0.1
